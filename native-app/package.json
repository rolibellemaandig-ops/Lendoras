{
  "name": "lendora",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint .",
    "build:ios": "cd ios && xcodebuild -workspace Lendora.xcworkspace -scheme Lendora -configuration Release -derivedDataPath build",
    "build:android": "cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/stack": "^6.3.20",
    "react-native-screens": "~3.27.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-gesture-handler": "~2.14.1",
    "@react-native-community/geolocation": "^2.1.0",
    "react-native-maps": "1.10.1",
    "react-native-image-picker": "^7.0.3",
    "react-native-camera": "^4.2.1",
    "react-native-push-notification": "^8.1.1",
    "@react-native-firebase/app": "^18.1.0",
    "@react-native-firebase/messaging": "^18.1.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "axios": "^1.6.2",
    "moment": "^2.29.4",
    "lottie-react-native": "6.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.8",
    "@types/react": "^18.2.37",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2"
  }
}
